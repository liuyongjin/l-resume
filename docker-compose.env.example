# 模板：复制为根目录 .env
#   cp docker-compose.env.example .env
# 内容应对齐 backend-nest/.env 与 backend-agent-python/.env

# ---------- backend-nest DATABASE_URL ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=l_resume

# ---------- backend-nest ----------
JWT_SECRET=default_secret_key_change_in_production
JWT_EXPIRES_IN=7d
PORT=3001
BASE_URL=http://localhost:3001
MULTIAGENT_SERVICE_URL=http://localhost:5001
OAUTH_ISSUER=http://localhost:9000
OAUTH_JWKS_URI=http://localhost:9000/oauth2/jwks

# ---------- backend-agent-python ----------
API_HOST=0.0.0.0
API_PORT=5001
AGENT_DEBUG=true
ZHIPU_API_KEY=your_zhipu_api_key_here

# ---------- Docker 专用 ----------
WEB_PORT=3000
NEST_LOG_LEVEL=info
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_REGISTRY=https://registry.npmmirror.com
